{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://cvoptima-backend.onrender.com/api/v1",
    "REACT_APP_ENVIRONMENT": "production",
    "REACT_APP_VERSION": "1.0.0"
  },
  "github": {
    "silent": true
  },
  "public": true,
  "regions": ["fra1"]
}